#include <iostream>

struct point {
    int x;
    int y;
};

std::ostream& operator<<(std::ostream& out, const point& p) {
    out << "(" << p.x << ", " << p.y << ")";
    return out;
}

std::istream& operator>>(std::istream& in, point& p) {
    in >> p.x >> p.y;
    return in;
}

int main() {
    point p;
    std::cout << "Enter x and y: ";
    std::cin >> p;        // User enters: 5 10
    std::cout << p << std::endl; // Output: (5, 10)
    return 0;
}
