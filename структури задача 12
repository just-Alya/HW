#include <iostream>
#include <string>

using namespace std;

struct Student {
    string name;
    int grade;
};

int main() {
    Student s[3];

    for (int i = 0; i < 3; i++) {
        cout << "Student " << i + 1 << " - name: ";
        cin >> s[i].name;
        cout << "Student " << i + 1 << " - grade: ";
        cin >> s[i].grade;
    }

    int bestIdx = 0;
    for (int i = 1; i < 3; i++) {
        if (s[i].grade > s[bestIdx].grade) {
            bestIdx = i;
        }
    }

    cout << "\nBest student: " << s[bestIdx].name << " (" << s[bestIdx].grade << ")" << endl;

    return 0;
}
