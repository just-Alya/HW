#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

struct Date {
    int day, month, year;
};

struct Time {
    int hours, minutes;
};

struct Event {
    string name;
    Date date;
    Time time;
};

int main() {
    Event e;

    cout << "Event name: "; cin >> e.name;
    cout << "Date - day: "; cin >> e.date.day;
    cout << "Date - month: "; cin >> e.date.month;
    cout << "Date - year: "; cin >> e.date.year;
    cout << "Time - hours: "; cin >> e.time.hours;
    cout << "Time - minutes: "; cin >> e.time.minutes;

    cout << "\nEvent: " << e.name << endl;
    cout << "When: " << setfill('0') << setw(2) << e.date.day << "."
         << setw(2) << e.date.month << "." << e.date.year << " at "
         << setw(2) << e.time.hours << ":" << setw(2) << e.time.minutes << endl;

    return 0;
}
