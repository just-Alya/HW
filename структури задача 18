#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

struct Product {
    string name;
    double price;
};

struct Order {
    Product product;
    int quantity;
};

int main() {
    Order myOrder;

    cout << "Product name: ";
    cin >> myOrder.product.name;
    cout << "Product price: ";
    cin >> myOrder.product.price;
    cout << "Order quantity: ";
    cin >> myOrder.quantity;

    double total = myOrder.product.price * myOrder.quantity;

    cout << fixed << setprecision(2);
    cout << "Order total: " << total << " UAH" << endl;

    return 0;
}
