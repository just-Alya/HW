#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

struct Product {
    string name;
    double price;
    int quantity;
};

int main() {
    Product p[3];
    double totalWarehouseValue = 0;

    for (int i = 0; i < 3; i++) {
        cout << "Product " << i + 1 << " - name: ";
        cin >> p[i].name;
        cout << "Product " << i + 1 << " - price: ";
        cin >> p[i].price;
        cout << "Product " << i + 1 << " - quantity: ";
        cin >> p[i].quantity;
        
        totalWarehouseValue += p[i].price * p[i].quantity;
    }

    cout << fixed << setprecision(2);
    cout << "Total warehouse value: " << totalWarehouseValue << " UAH" << endl;

    return 0;
}
