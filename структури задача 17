#include <iostream>
#include <cmath>
#include <iomanip>

using namespace std;

struct Point {
    double x;
    double y;
};

struct Segment {
    Point start;
    Point end;
};

int main() {
    Segment s;

    cout << "Start point - x: "; cin >> s.start.x;
    cout << "Start point - y: "; cin >> s.start.y;
    cout << "End point - x: ";   cin >> s.end.x;
    cout << "End point - y: ";   cin >> s.end.y;

    double length = sqrt(pow(s.end.x - s.start.x, 2) + pow(s.end.y - s.start.y, 2));

    cout << fixed << setprecision(2);
    cout << "Segment length: " << length << endl;

    return 0;
}
