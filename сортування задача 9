template<typename T>
int partition_first(vector<T>& v, int low, int high) {
    T pivot = v[low];
    int i = low + 1;
    for (int j = low + 1; j <= high; ++j) {
        if (v[j] < pivot) {
            swap(v[i], v[j]);
            i++;
        }
    }
    swap(v[low], v[i - 1]);
    return i - 1;
}
