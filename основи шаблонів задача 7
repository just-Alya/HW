#include <iostream>

template<typename T>
struct vector {
    T* data;
    int size;
    int capacity;

    void print() {
        std::cout << "[";
        for (int i = 0; i < size; ++i) {
            std::cout << data[i];
            if (i < size - 1) {
                std::cout << ", ";
            }
        }
        std::cout << "]" << std::endl;
    }
};

// Для тестування з власним типом point
struct point {
    int x, y;
};

std::ostream& operator<<(std::ostream& out, const point& p) {
    out << "(" << p.x << ", " << p.y << ")";
    return out;
}

int main() {
    // Приклад з int
    int int_data[] = {1, 2, 3};
    vector<int> v{int_data, 3, 3};
    v.print(); // [1, 2, 3]

    // Приклад з point
    point point_data[] = {{0, 0}, {1, 1}};
    vector<point> points{point_data, 2, 2};
    points.print(); // [(0, 0), (1, 1)]

    return 0;
}
