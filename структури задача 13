#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

struct Student {
    string name;
    double grade;
};

int main() {
    Student s[3];
    double sum = 0;

    for (int i = 0; i < 3; i++) {
        cout << "Student " << i + 1 << " - name: ";
        cin >> s[i].name;
        cout << "Student " << i + 1 << " - grade: ";
        cin >> s[i].grade;
        sum += s[i].grade;
    }

    cout << fixed << setprecision(2);
    cout << "Average grade: " << sum / 3.0 << endl;

    return 0;
}
