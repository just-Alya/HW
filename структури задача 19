#include <iostream>
#include <cmath>
#include <iomanip>

using namespace std;

struct Point {
    double x;
    double y;
};

struct Rectangle {
    Point bottomLeft;
    Point topRight;
};

int main() {
    Rectangle r;

    cout << "Bottom-left - x: "; cin >> r.bottomLeft.x;
    cout << "Bottom-left - y: "; cin >> r.bottomLeft.y;
    cout << "Top-right - x: ";   cin >> r.topRight.x;
    cout << "Top-right - y: ";   cin >> r.topRight.y;

    double width = abs(r.topRight.x - r.bottomLeft.x);
    double height = abs(r.topRight.y - r.bottomLeft.y);
    double area = width * height;

    cout << fixed << setprecision(2);
    cout << "Area: " << area << endl;

    return 0;
}
