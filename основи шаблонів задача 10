#include <iostream>

template<typename T>
void swap(T& a, T& b) {
    T temp = a;
    a = b;
    b = temp;
}

int main() {
    // Приклад з int
    int x = 5, y = 10;
    std::cout << "Before swap: x = " << x << ", y = " << y << std::endl;
    swap(x, y);
    std::cout << "After swap:  x = " << x << ", y = " << y << std::endl;

    // Приклад з double
    double a = 3.14, b = 2.71;
    std::cout << "\nBefore swap: a = " << a << ", b = " << b << std::endl;
    swap(a, b);
    std::cout << "After swap:  a = " << a << ", b = " << b << std::endl;

    return 0;
}
