#include <iostream>

struct point {
    int x;
    int y;
    int z;
};

std::ostream& operator<<(std::ostream& out, const point& p) {
    out << "(" << p.x << ", " << p.y << ", " << p.z << ")";
    return out;
}

std::istream& operator>>(std::istream& in, point& p) {
    in >> p.x >> p.y >> p.z;
    return in;
}

int main() {
    point p;
    std::cout << "Введіть x, y, z: ";
    std::cin >> p;
    std::cout << "Ви ввели: " << p << std::endl;
    return 0;
}
