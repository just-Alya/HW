#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

struct Product {
    string name;
    double price;
};

int main() {
    Product p[3];

    for (int i = 0; i < 3; i++) {
        cout << "Product " << i + 1 << " - name: ";
        cin >> p[i].name;
        cout << "Product " << i + 1 << " - price: ";
        cin >> p[i].price;
    }

    int minIdx = 0;
    for (int i = 1; i < 3; i++) {
        if (p[i].price < p[minIdx].price) {
            minIdx = i;
        }
    }

    cout << fixed << setprecision(2);
    cout << "\nCheapest: " << p[minIdx].name << " (" << p[minIdx].price << " UAH)" << endl;

    return 0;
}
